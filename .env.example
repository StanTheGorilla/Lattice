# =============================================================
# Lattice — environment variables
# Copy to .env (gitignored) and fill in values per phase.
# =============================================================

# --- general ---
TIMEZONE=Europe/Warsaw
# When true, APScheduler is disabled in the backend process.
# Required during dev with uvicorn --reload (reload spawns duplicate schedulers).
LATTICE_DISABLE_SCHEDULER=true

# --- web UI auth (single user) ---
# Password used to log into the web UI. 30-day cookie session.
WEB_UI_PASSWORD=

# --- bot ↔ backend shared secret ---
# Sent as X-Bot-Token header from bot to backend.
BOT_SHARED_SECRET=

# --- Garmin Connect (Phase 2B) ---
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Google Calendar OAuth (Phase 2C) ---
# OAuth client created in Google Cloud Console (Desktop app).
# credentials.json lives at backend/lattice/integrations/credentials.json
# token.json is written to %USERPROFILE%/.lattice/google_token.json on first run.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Discord bot (Phase 2G) ---
DISCORD_BOT_TOKEN=
# Owner Discord user ID — bot DMs go to this user.
DISCORD_OWNER_ID=

# --- DeepSeek (Phase 2G chat agent + 2I weekly report) ---
DEEPSEEK_API_KEY=
# Optional: override model ids. Defaults are deepseek-chat / deepseek-reasoner.
# DEEPSEEK_MODEL_DEFAULT=deepseek-chat
# DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# --- Daily LLM token budget (SPEC §7.4) ---
# Hard cap. Chat replies with 429 once exceeded; weekly report falls back to
# its deterministic summary. Counters reset at local midnight.
# LATTICE_DAILY_TOKEN_BUDGET_INPUT=200000
# LATTICE_DAILY_TOKEN_BUDGET_OUTPUT=50000

# --- Research agent (web search) ---
# Tavily API key for web search in the research agent. Get one at tavily.com (~$5/mo).
TAVILY_API_KEY=
# Optional: override research papers directory (default: data/research).
# LATTICE_RESEARCH_DIR=data/research
